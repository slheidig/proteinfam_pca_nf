/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    og-b2bpca Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

plugins {
    id 'nf-schema@2.1.1'
}

// Prefer VSC_SCRATCH_VO_USER and never fall back to HOME; use repo-relative './.apptainer' if unset
def apptainercache = (System.getenv('VSC_SCRATCH_VO_USER') ?: './') + '/.apptainer'

params {
    // Input/output
    og_dir                  = null
    outdir                  = 'results'

    // Pipeline behaviour
    min_seqs                = 10
    b2b_batch_size          = 1000
    alignment_batch_size    = 100
    external_labels         = null
    chunk_size              = 100
    // Boilerplate
    help                    = false
    version                 = false
    monochrome_logs         = false
    validate_params         = true
}

// Load base resource config
includeConfig 'conf/base.config'

// Load per-module publish/args config
includeConfig 'conf/modules.config'

profiles {
    test {
        includeConfig 'conf/test.config'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = apptainercache
    }
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
    }
}

// Prevent local Python/Perl libraries from bleeding in
env {
    PYTHONNOUSERSITE = 1
    APPTAINER_CACHEDIR = apptainercache
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

nextflow.enable.configProcessNamesValidation = false

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

manifest {
    name            = 'og-b2bpca'
    description     = 'Detect structural-dynamic clusters within orthogroups using b2bTools and PCA'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '1.0.0'
}
