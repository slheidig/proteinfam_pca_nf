/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    og-b2bpca Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Prefer VSC_SCRATCH_VO_USER and never fall back to HOME; use repo-relative './.apptainer' if unset
def apptainercache = (System.getenv('VSC_SCRATCH_VO_USER') ?: './') + '/.apptainer'

params {
    // Input/output
    og_dir                  = null
    outdir                  = 'results'

    // Pipeline behaviour
    min_seqs                = 10
    b2b_batch_size          = 1000
    alignment_batch_size    = 100
    external_labels         = null
    aligned                 = false
    distance_type           = 'b2b_distance'
}

// Base resource config
process {
    cpus   = { 1    * task.attempt }
    memory = { 6.GB * task.attempt }
    time   = { 1.h  * task.attempt }

    errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    maxRetries    = 2

    withLabel: process_single {
        cpus   = { 2                   }
        memory = { 4.GB * task.attempt * task.attempt}
        time   = { 0.5.h  * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 2     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 0.5.h   * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 6.GB * task.attempt * task.attempt}
        time   = { 1.h   * task.attempt }
    }
    withLabel: process_highmem{
        cpus   = { 2     * task.attempt }
        memory = { 40.GB * task.attempt }
        time   = { 1.h   * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel: process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel: error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel: error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}

// Per-module publishDir paths and extra args
process {

    withName: 'POOL_SEQUENCES' {
        publishDir = [
            path: { "${params.outdir}/pool_sequences" },
            mode: 'copy',
            enabled: false
        ]
    }

    withName: 'B2BTOOLS' {
        publishDir = [
            path: { "${params.outdir}/distance_matrices/b2b_distance" },
            mode: 'copy',
            pattern: 'batch_*_b2b.tsv',
            enabled: false
        ]
    }

    withName: 'REATTACH_B2B' {
        publishDir = [
            path: { "${params.outdir}/distance_matrices/b2b_distance" },
            mode: 'copy',
            pattern: '*_b2b.tsv'
        ]
    }

    withName: 'MAFFT' {
        ext.args   = '--reorder --auto'
        publishDir = [
            path: { "${params.outdir}/alignments/mafft" },
            mode: 'copy',
            pattern: '*.aln.fa'
        ]
    }

    withName: 'MMSEQS2_EASYSEARCH' {
        ext.args   = '-e 1000000 --min-seq-id 0.0 -s 7.5'
        publishDir = [
            path: { "${params.outdir}/alignments/mmseqs" },
            mode: 'copy',
            pattern: '*.pairali.tsv'
        ]
    }

    withName: 'B2B_DISTANCE_MATRIX' {
        publishDir = [
            path: { "${params.outdir}/distance_matrices/b2b_distance" },
            mode: 'copy',
            pattern: '*.{csv,tsv}'
        ]
    }

    withName: 'PCA_CLUSTERING' {
        publishDir = [
            path: { "${params.outdir}/pca" },
            mode: 'copy',
            pattern: '**/*.{png,csv}'
        ]
    }

    withName: 'SUMMARY_PLOT' {
        publishDir = [
            path: { "${params.outdir}/cluster_counts" },
            mode: 'copy',
            pattern: '*.{png,csv}'
        ]
    }

    withName: 'SEQUENCE_IDENTITY_MATRIX' {
        publishDir = [
            path: { "${params.outdir}/distance_matrices/seq_distance" },
            mode: 'copy',
            pattern: '*_identity_matrix.csv'
        ]
    }

    withName: 'PLOT_BOTH_HEATMAPS' {
        publishDir = [
            path: { "${params.outdir}/pca" },
            mode: 'copy',
            pattern: '**/*_heatmap.png'
        ]
    }
}

// Prevent local Python/Perl libraries from bleeding in
env {
    PYTHONNOUSERSITE = 1
    APPTAINER_CACHEDIR = apptainercache
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

nextflow.enable.configProcessNamesValidation = false

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

profiles {
    test {
        params {
            og_dir         = "${projectDir}/tests/data/ogs"
            outdir         = 'test_results'
            min_seqs       = 3
            b2b_batch_size = 50
        }
        process {
            cpus = 2
            withLabel: process_single { cpus = 1; memory = '2.GB'; time = '30.min' }
            withLabel: process_low { cpus = 2; memory = '4.GB'; time = '30.min' }
            withLabel: process_medium { cpus = 2; memory = '4.GB'; time = '30.min' }
            withLabel: process_high { cpus = 2; memory = '4.GB'; time = '30.min' }
            withLabel: process_long { cpus = 2; memory = '4.GB'; time = '30.min' }
            withLabel: process_highmem{ cpus = { 2 * task.attempt }; memory = { 4.GB * task.attempt }; time = { 1.h * task.attempt } }
        }
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = apptainercache
    }
    docker {
        docker.enabled = true
    }
}

manifest {
    name            = 'og-b2bpca'
    description     = 'Detect structural-dynamic clusters within orthogroups using b2bTools and PCA'
    mainScript      = 'workflow.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '1.0.0'
}
