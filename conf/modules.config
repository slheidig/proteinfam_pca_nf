/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-module publishDir paths and extra args
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: 'POOL_SEQUENCES' {
        publishDir = [
            path: { "${params.outdir}/pool_sequences" },
            mode: 'copy',
            enabled: false      // intermediate; not saved by default
        ]
    }

    withName: 'B2BTOOLS' {
        publishDir = [
            path: { "${params.outdir}/b2btools/batches" },
            mode: 'copy',
            pattern: '*.tsv',
            enabled: false      // batch TSVs are intermediate; per-OG TSVs saved after reattach
        ]
    }

    withName: 'REATTACH_B2B' {
        publishDir = [
            path: { "${params.outdir}/b2b_predictions" },
            mode: 'copy',
            pattern: '*_b2b.tsv'
        ]
    }

    withName: 'MAFFT' {
        ext.args   = '--reorder --auto'
        publishDir = [
            path: { "${params.outdir}/mafft/${meta.id}" },
            mode: 'copy',
            pattern: '*.aln.fa'
        ]
    }

    withName: 'MMSEQS2_EASYSEARCH' {
        // --format-output columns (tab-separated, no header):
        // query target qaln taln qstart qend tstart tend qlen tlen pident evalue
        ext.args   = '-e 1000000 --min-seq-id 0.0 -s 7.5'
        publishDir = [
            path: { "${params.outdir}/mmseqs2/${meta.id}" },
            mode: 'copy',
            pattern: '*.tsv'
        ]
    }

    withName: 'B2B_DISTANCE_MATRIX' {
        publishDir = [
            path: { "${params.outdir}/distance_matrices/${meta.id}" },
            mode: 'copy',
            pattern: '*.{csv,tsv}'
        ]
    }

    withName: 'PCA_CLUSTERING' {
        publishDir = [
            path: { "${params.outdir}/pca/${meta.id}" },
            mode: 'copy',
            pattern: '*.{png,csv}'
        ]
    }

    withName: 'SUMMARY_PLOT' {
        publishDir = [
            path: { "${params.outdir}/summary" },
            mode: 'copy',
            pattern: '*.{png,csv}'
        ]
    }
}
