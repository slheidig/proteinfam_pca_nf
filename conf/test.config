/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal test profile — 5 OGs, relaxed thresholds
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline logic end-to-end'

    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '2.h'

    og_dir         = "${projectDir}/tests/data/ogs"
    outdir         = 'test_results'
    min_seqs       = 3
    b2b_batch_size = 50
}

process {
    cpus = 2

    withLabel: process_single {
        cpus = 1
        memory = '2.GB'
        time = '30.min'
    }
    withLabel: process_low {
        cpus = 2
        memory = '4.GB'
        time = '30.min'
    }
    withLabel: process_medium {
        cpus = 2
        memory = '4.GB'
        time = '30.min'
    }
    withLabel: process_high {
        cpus = 2
        memory = '4.GB'
        time = '30.min'
    }
    withLabel: process_long {
        cpus = 2
        memory = '4.GB'
        time = '30.min'
    }
}
