{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "og-b2bpca og directory",
    "description": "Directory containing orthogroup FASTA files (*.fa).",
    "type": "object",
    "required": ["og_dir"],
    "properties": {
        "og_dir": {
            "type": "string",
            "format": "directory-path",
            "exists": true,
            "description": "Path to folder with OG FASTA files using .fa extension."
        }
    }
}
